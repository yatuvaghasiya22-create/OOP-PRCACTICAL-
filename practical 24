class NumberThread extends Thread {
    private int start;
    private int end;

    public NumberThread(int start, int end) {
        this.start = start;
        this.end = end;
    }

    public void run() {
        for (int i = start; i <= end; i++) {
            System.out.println(i);
        }
    }
}

public class SequentialThreads {
    public static void main(String[] args) {
        Thread t1 = new NumberThread(1, 100);
        Thread t2 = new NumberThread(101, 200);
        Thread t3 = new NumberThread(201, 300);

        t1.start();
        try {
            t1.join();
        } catch (InterruptedException e) {
            System.out.println(e.getMessage());
        }

        t2.start();
        try {
            t2.join();
        } catch (InterruptedException e) {
            System.out.println(e.getMessage());
        }

        t3.start();
        try {
            t3.join();
        } catch (InterruptedException e) {
            System.out.println(e.getMessage());
        }
    }
}
