import java.util.LinkedList;

public class GenericSearch {

    public static <T> boolean searchElement(LinkedList<T> list, T element) {
        return list.contains(element);
    }

    public static void main(String[] args) {
        LinkedList<Integer> rollNumbers = new LinkedList<>();
        rollNumbers.add(101);
        rollNumbers.add(102);
        rollNumbers.add(103);
        rollNumbers.add(104);

        System.out.println("Search 102 in roll numbers: " + searchElement(rollNumbers, 102));
        System.out.println("Search 999 in roll numbers: " + searchElement(rollNumbers, 999));

        LinkedList<String> names = new LinkedList<>();
        names.add("John");
        names.add("Emma");
        names.add("Alex");

        System.out.println("Search Emma in names: " + searchElement(names, "Emma"));
        System.out.println("Search Mike in names: " + searchElement(names, "Mike"));
    }
}
